---
import '../styles/global.css'

interface Props {
  title: string
  description?: string
}

const { title, description = "Infiniti's Wiki — technical writing on infrastructure, security, and software." } = Astro.props
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} — Infiniti's Wiki</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <slot />
</body>
</html>
