---
interface Props {
  caption?: string
  alt?: string
}

const { caption, alt = '' } = Astro.props
---

<figure class="diagram">
  <div class="diagram-inner" role="img" aria-label={alt}>
    <slot />
  </div>
  {caption && <figcaption class="diagram-caption">{caption}</figcaption>}
</figure>

<style>
  .diagram {
    margin: 2.5rem 0;
  }

  .diagram-inner {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 2rem;
    overflow-x: auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .diagram-inner :global(svg) {
    max-width: 100%;
    height: auto;
  }

  .diagram-caption {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-faint);
    letter-spacing: 0.04em;
    text-align: center;
    margin-top: 0.75rem;
  }
</style>
